# Monad Testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Deployer private key (for contract deployment only, NEVER commit)
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# Backend
PORT=3001

# Deployed contract addresses (updated after deployment)
NEXT_PUBLIC_SIMPLE_STORAGE_ADDRESS=0x_deployed_address_here
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
